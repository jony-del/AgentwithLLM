# API Keys
# Anthropic: https://console.anthropic.com/
# ANTHROPIC_API_KEY="sk-ant-xxx"
# OpenAI: https://platform.openai.com/
OPENAI_API_KEY="sk-xxx"

# Agent defaults
# AGENT_MODEL=claude-haiku-4-5-20251001
# AGENT_PERMISSION=default
# AGENT_PROVIDER=claude
AGENT_MODEL=gpt-4.1-nano
AGENT_PERMISSION=default
AGENT_PROVIDER=openai

# Claude / Anthropic Messages API — run with: --provider claude
# Requests POST {ANTHROPIC_BASE_URL}/v1/messages.
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# =============================================================================
#  Anthropic-compatible Messages providers
#
#  These endpoints speak the Anthropic Messages protocol and therefore still use
#  --provider claude. Provider choice is never inferred from model name/base URL.
#
#  Provider         MODEL_ID              SWE-bench  TB2     Base URL
#  ---------------  --------------------  ---------  ------  -------------------
#  Anthropic        claude-sonnet-4-6     79.6%      59.1%   (default)
#  MiniMax          MiniMax-M2.5          80.2%        -     see below
#  GLM (Zhipu)      glm-5                77.8%        -     see below
#  Kimi (Moonshot)  kimi-k2.5            76.8%        -     see below
#  DeepSeek         deepseek-chat        73.0%        -     see below
#                   (V3.2)
# =============================================================================

# ---- International ----

# MiniMax          https://www.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimax.io/anthropic
# AGENT_MODEL=MiniMax-M2.5

# GLM (Zhipu)      https://z.ai
# ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# AGENT_MODEL=glm-5

# Kimi (Moonshot)  https://platform.moonshot.ai
# ANTHROPIC_BASE_URL=https://api.moonshot.ai/anthropic
# AGENT_MODEL=kimi-k2.5

# DeepSeek         https://platform.deepseek.com
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# AGENT_MODEL=deepseek-chat

# ---- China mainland ----

# MiniMax          https://platform.minimax.io
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# AGENT_MODEL=MiniMax-M2.5

# GLM (Zhipu)      https://open.bigmodel.cn
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# AGENT_MODEL=glm-5

# Kimi (Moonshot)  https://platform.moonshot.cn
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# AGENT_MODEL=kimi-k2.5

# DeepSeek (no regional split, same endpoint globally)
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# AGENT_MODEL=deepseek-chat

# =============================================================================
#  OpenAI official Responses API — run with: --provider openai
#
#  Requests POST {OPENAI_BASE_URL}/v1/responses. Polaris replays input/output
#  items locally (store=false) and does not use previous_response_id as the only
#  context source. Provider choice is explicit: a model id or base URL never
#  switches this provider to Chat Completions. GPT reasoning capabilities are
#  gated by a conservative model-specific local matrix: supported effort values
#  can include none/minimal/low/medium/high/xhigh/max, `none` is sent explicitly
#  when supported, unknown models do not receive reasoning-only fields, unsupported
#  effort values are omitted, encrypted reasoning is replayed opaquely, and only
#  displayable summaries reach the UI. Use an OpenAI model id accepted by your
#  account/API.
# =============================================================================

# OPENAI_API_KEY="sk-xxx"
# OPENAI_BASE_URL=https://api.openai.com
# AGENT_PROVIDER=openai
# AGENT_MODEL=gpt-4.1-mini

# =============================================================================
#  OpenAI-compatible Chat Completions — run with: --provider openai-compat
#
#  Requests POST {OPENAI_COMPAT_BASE_URL}/v1/chat/completions. Use this for
#  DeepSeek, Qwen, GLM, Moonshot, vLLM, LM Studio, Groq, llama.cpp servers, etc.
#  Legacy OPENAI_API_KEY / OPENAI_BASE_URL still work as a fallback for this
#  provider but emit a deprecated warning; prefer the COMPAT variables below.
#
#  Migration: old `--provider openai` + `OPENAI_BASE_URL=<compat endpoint>` should
#  become `--provider openai-compat` + `OPENAI_COMPAT_BASE_URL=<compat endpoint>`.
# =============================================================================

# OPENAI_COMPAT_API_KEY="sk-or-placeholder"
# OPENAI_COMPAT_BASE_URL=http://localhost:8000
# AGENT_PROVIDER=openai-compat
# AGENT_MODEL=local-model
