# Example agent.toml — copy to `agent.toml` and edit. All keys are optional;
# anything omitted falls back to the built-in defaults.
#
# Precedence (lowest to highest): built-in defaults -> this file ->
# AGENT_MODEL / AGENT_PERMISSION / AGENT_PROVIDER / AGENT_MEMORY env vars -> CLI flags.

# --- Top-level scalars -------------------------------------------------------
model = "claude-haiku-4-5-20251001"
permission = "default"        # default | acceptedits | plan | auto | dontask
provider = "claude"           # claude | fake

# --- Live display (CLI-only, NOT configured here) ----------------------------
# The terminal trace, token streaming, and extended thinking are controlled by
# CLI flags, not this file or env vars. They only activate with the interactive
# ConsoleUI (stdin AND stdout are TTYs); pipes/tests stay silent. Available flags:
#   --quiet              suppress the live thinking/tool trace (final answer only)
#   --no-stream          render each turn after it completes (no token-by-token)
#   --thinking-budget N  enable Claude extended thinking with an N-token budget
# Permission prompts in the live UI accept: y (once) / a (always this session) / n (deny).

# --- Cross-conversation memory ----------------------------------------------
# The whole table is optional. `enabled` here can be overridden by AGENT_MEMORY
# or the --memory / --no-memory CLI flag; the numeric tunables below are only
# configurable via this file.
[memory]
enabled = true               # turn recall + extraction on by default
dir = "memory"                # where memory.jsonl lives (gitignored)

# Recall: how relevant past memories are selected and ranked.
recall_k = 5                  # how many memories to inject per run
w_relevance = 1.0             # weight: lexical overlap with the task
w_importance = 0.5            # weight: stored salience
w_recency = 0.3               # weight: how recently the memory was used
recency_decay_per_hour = 0.01 # exponential recency decay rate

# Extraction: distilling durable memories after a run.
auto_extract = true           # extract automatically when a run completes
dedup_threshold = 0.85        # skip a new memory this similar to an existing one

# Dreaming: offline consolidation (`python -m agent_core dream`).
forget_threshold = 0.15       # drop memories whose decayed importance falls below this
forget_min_access = 1         # ...unless they've been recalled at least this many times
importance_half_life_days = 14.0  # forgetting curve half-life
merge_threshold = 0.6         # fuse two memories above this lexical similarity
synthesize_insights = true    # let the LLM infer higher-level "insight" memories

# --- MCP servers (Model Context Protocol) -----------------------------------
# Optional. Each [mcp.servers.<name>] connects one MCP server and exposes its tools
# to the agent as "<name>__<tool>" (e.g. fs__read_file). Needs the optional SDK:
#   pip install -e ".[mcp]"            # just the SDK (enough for your own servers)
#   pip install -e ".[mcp-servers]"    # SDK + the official git/fetch/time servers
# Every tool defaults to risk = "dangerous" (so it's denied in auto/dontask and
# confirmed in default); set risk per server to "read" or "write" to relax that.
# Inspect what a server exposes with:  python -m agent_core mcp list
#
# # stdio transport — launch a server as a subprocess:
# [mcp.servers.fs]
# transport = "stdio"
# command = "python"
# args = ["-m", "mcp_server_filesystem", "."]
# # env = { SOME_VAR = "value" }   # extra env layered over the inherited environment
# # cwd = "."                       # working directory for the subprocess
# risk = "read"
#
# # Streamable HTTP transport (2025 spec, single endpoint) — connect to a URL:
# [mcp.servers.weather]
# transport = "streamable-http"
# url = "http://localhost:8000/mcp"
# headers = { Authorization = "Bearer TOKEN" }
# risk = "write"
#
# --- Popular community servers (uncomment + install to enable) ---------------
# These are Node-based; they run via `npx -y <pkg>` (needs Node/npm on PATH) and
# are NOT in the `mcp-servers` extra (that extra only carries the pip git/fetch/time
# servers). Each needs its own setup (tokens, paths) — see the package's README.
#
# # GitHub: repos, issues, PRs, code search. Needs a personal access token.
# [mcp.servers.github]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-github"]
# env = { GITHUB_PERSONAL_ACCESS_TOKEN = "ghp_..." }
# risk = "write"
#
# # Playwright: drive a real browser (navigate, click, screenshot, scrape).
# [mcp.servers.playwright]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@playwright/mcp@latest"]
# risk = "dangerous"
#
# # SQLite: query/inspect a local database file.
# [mcp.servers.sqlite]
# transport = "stdio"
# command = "npx"
# args = ["-y", "mcp-server-sqlite-npx", "./app.db"]
# risk = "write"
#
# # Sequential-thinking: a structured step-by-step reasoning scratchpad.
# [mcp.servers.sequential-thinking]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]
# risk = "read"

[mcp.servers.git]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_git", "--repository", "."]
risk = "write"

[mcp.servers.fetch]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_fetch"]
env = { PYTHONIOENCODING = "utf-8" }
risk = "read"

[mcp.servers.time]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_time", "--local-timezone=Asia/Shanghai"]
risk = "read"

# --- Single tool-output truncation ------------------------------------------
# When one tool call's output exceeds these limits, only head+tail (with a
# "[... omitted N lines ...]" notice) enters the context; the full, untouched
# output is written to runs/<run>/outputs/ for later retrieval.
[output]
max_lines = 100               # truncate when output has more lines than this
max_chars = 8000              # fallback cap for pathological single-line output
head_lines = 20               # lines kept from the start
tail_lines = 20               # lines kept from the end
spill = true                  # write the full output to disk (false = drop it)
