# Example agent.toml — copy to `agent.toml` and edit. All keys are optional;
# anything omitted falls back to the built-in defaults.
#
# Precedence (lowest to highest): built-in defaults -> this file ->
# AGENT_MODEL / AGENT_PERMISSION / AGENT_PROVIDER / AGENT_MEMORY env vars -> CLI flags.

# --- Top-level scalars -------------------------------------------------------
model = "claude-opus-4-8"
permission = "default"        # default | acceptedits | plan | auto | dontask
provider = "claude"           # claude | fake
# output_config.effort depth/cost control. low | medium | high | xhigh | max.
# "high" is the safe agentic default; "xhigh" is Opus 4.8-best for coding but errors on
# Sonnet 4.6 / Opus <= 4.6 (the provider drops a level the model can't honor). Overridable
# by AGENT_EFFORT or --effort. Only effort-capable models (Opus 4.5+, Sonnet 4.6, Fable) use it.
effort = "high"

# --- Live display (CLI-only, NOT configured here) ----------------------------
# The terminal trace, token streaming, and extended thinking are controlled by
# CLI flags, not this file or env vars. They only activate with the interactive
# ConsoleUI (stdin AND stdout are TTYs); pipes/tests stay silent. Available flags:
#   --quiet              suppress the live thinking/tool trace (final answer only)
#   --no-stream          render each turn after it completes (no token-by-token)
#   --thinking-budget N  enable Claude extended thinking with an N-token budget
# Permission prompts in the live UI accept: y (once) / a (always this session) / n (deny).

# --- Cross-conversation memory ----------------------------------------------
# The whole table is optional. `enabled` here can be overridden by AGENT_MEMORY
# or the --memory / --no-memory CLI flag; the numeric tunables below are only
# configurable via this file.
[memory]
enabled = true               # turn recall + extraction on by default
dir = "memory"                # where memory.jsonl lives (gitignored)

# Recall: how relevant past memories are selected and ranked.
recall_k = 5                  # how many memories to inject per run
w_relevance = 1.0             # weight: lexical overlap with the task
w_importance = 0.5            # weight: stored salience
w_recency = 0.3               # weight: how recently the memory was used
recency_decay_per_hour = 0.01 # exponential recency decay rate

# Extraction: distilling durable memories after a run.
auto_extract = true           # extract automatically when a run completes
dedup_threshold = 0.85        # skip a new memory this similar to an existing one

# Dreaming: offline consolidation (`python -m agent_core dream`).
forget_threshold = 0.15       # drop memories whose decayed importance falls below this
forget_min_access = 1         # ...unless they've been recalled at least this many times
importance_half_life_days = 14.0  # forgetting curve half-life
merge_threshold = 0.6         # fuse two memories above this lexical similarity
synthesize_insights = true    # let the LLM infer higher-level "insight" memories

# --- Run-level safety limits ------------------------------------------------
# Bound a whole `run()`. The wall-clock budget is SHARED across the sub-agent
# fan-out (leader + children), not refreshed per child. Cooperative cancel (Esc)
# is the primary interactive control; these are the runaway/stuck safety net.
# Overridable by env (AGENT_MAX_WALL_SECONDS, AGENT_MAX_STEPS) and CLI flags
# (--max-wall-seconds, --max-steps). For both caps, 0 means "disabled".
[limits]
max_wall_seconds = 1800        # whole-run wall-clock budget in seconds; 0 = no limit
max_steps = 0                  # hard ceiling on tool turns; 0 = no cap
# Fraction of the wall budget after which a one-time "wrap up now" nudge is injected
# so the model can return a useful partial answer before the hard stop. >= 1 disables it.
soft_deadline_fraction = 0.9

# --- Resumable session transcripts ------------------------------------------
# Each run/chat records its conversation as an append-only transcript so it can be
# resumed later (`--resume <id>` / `--continue`, or `polaris sessions` to list).
# Transcripts are scoped per project under this root (a sanitized-cwd subdir), so a
# session resumes only where it was created (plus a cross-project id lookup as a
# fallback). `~` is expanded. Set to "" (or pass --no-session-persistence) to disable.
# Also settable via the AGENT_SESSION_DIR env var.
[session]
dir = "~/.polaris/projects"
# When true (default), a context-compaction fold writes a compact boundary + summary into
# the transcript, so resuming loads the *compacted* state (only turns after the last
# boundary) — like the reference. Set false to keep transcripts a faithful full record and
# have resume reload everything (the loop re-compacts). Env: AGENT_PERSIST_COMPACT_BOUNDARY.
persist_compaction_boundary = true

# --- One-time project context (CLAUDE.md + git) -----------------------------
# At run start the agent discovers CLAUDE.md files (workspace up to the root, plus
# ~/.claude/CLAUDE.md) and injects them as a pinned system block the model must
# follow. It also captures a one-shot git snapshot (branch, main branch, user,
# `git status --short`, last 5 commits) and injects it as a second pinned block,
# wrapped as untrusted context. Both blocks survive compaction and degrade silently
# (no CLAUDE.md / not a git repo / git missing). Toggle here or with truthy
# AGENT_DISABLE_CLAUDE_MD / AGENT_DISABLE_GIT_CONTEXT env vars.
[context]
project_instructions = true    # false (or AGENT_DISABLE_CLAUDE_MD=1) skips CLAUDE.md injection
git_context = true             # false (or AGENT_DISABLE_GIT_CONTEXT=1) skips the git snapshot
claudemd_max_chars = 32000     # truncate the joined block to this many characters

# --- Skills / slash commands ------------------------------------------------
# A skill is a Markdown file (SKILL.md + frontmatter) holding a reusable prompt.
# Skills load eagerly at startup from (low->high precedence): bundled (shipped) ->
# user_dir -> project_dir -> skills_dirs. A human triggers one with `/name args` in
# chat; the model can invoke one via the `skill` tool (hidden when nothing is
# model-invocable). Each skill's frontmatter sets context (inline|fork),
# user-invocable, and disable-model-invocation. AGENT_SKILLS=0 disables the system.
[skills]
enabled = true                 # false (or AGENT_SKILLS=0) turns the subsystem off
user_dir = "~/.polaris/skills"     # per-user skills (<name>/SKILL.md or <name>.md)
project_dir = ".polaris/skills"    # per-project skills, resolved against the workspace
skills_dirs = []               # extra highest-precedence directories to scan
disabled = []                  # skill names to suppress (e.g. ["commit"])

# --- Lifecycle hooks --------------------------------------------------------
# Two sources feed the five lifecycle hooks (UserPromptSubmit / PostSampling /
# PreCompact / PostCompact / Stop), both folded into one pipeline:
#   * Built-in programmatic hooks (in-process, hold live objects) — toggled below.
#   * Config-driven external hooks ([[hooks.external]]) — subprocess / HTTP / re-prompt
#     / verifier agent, declared here without touching code.
# Any hook failure degrades to "allow + log" and never sinks a run.
[hooks]
enabled = true                 # false (or AGENT_HOOKS=0) turns the whole subsystem off

[hooks.builtin]
stop_completion = true         # block a stop once if update_todos still has open items,
                               #   injecting a continuation directive (capped by max_stop_blocks)
post_sampling_observer = true  # fire-and-forget turn telemetry to runs/*.jsonl (hook_observe)
compaction_logger = true       # log trigger + pre/post message & summary sizes around a fold

# UserPromptSubmit input firewall — validates each submitted task before the first model call.
# Provenance-based: the harness's control framing (<system-reminder>, <tool_output_ref>, ...) is
# trusted only because it comes from the framework's own injection path; the same tags appearing
# inside a user task are untrusted DATA. Rules in priority order: empty -> block; over max_chars
# -> block (paste-bomb / context-overflow guard); disallowed control chars -> block; reserved
# framing tags -> NEUTRALIZE not reject (escape the tags, wrap the task in an
# <untrusted_user_input> envelope, prepend a guard preamble, and audit it in runs/*.jsonl). A
# neutralized prompt is what gets persisted + sent. Any internal error degrades to allow.
[hooks.prompt_validation]
enabled = true                 # on by default; false skips the firewall entirely
max_chars = 100000             # reject prompts larger than this; 0 disables the size cap
reject_control_chars = true    # reject NUL / C0 control chars (tab/newline/CR are allowed)
neutralize_framing = true      # wrap+escape spoofed control framing instead of rejecting it

# External hooks: a flat array, each entry names its `event` + `type`. Only `command`/`http`
# carry the block contract (exit code 2 / JSON {"continue": false} = block; stdout
# {"hookSpecificOutput": {"additionalContext": "..."}} is injected). `prompt`/`agent` are
# advisory (inject the model/sub-agent reply as context, never block). `matcher` only
# applies to Pre/PostCompact (matched against the trigger: "auto" | "reactive"). Every call
# is bounded by a single `timeout` (seconds) with kill-await; the hook receives a bounded
# JSON projection of the context on stdin / as the request body.
# SECURITY: these run arbitrary commands/URLs from THIS project's agent.toml — only enable
# hooks you trust.
#
[[hooks.external]]
event = "UserPromptSubmit"
type = "command"
command = "python3 ./.polaris/hooks/validate_prompt.py"
timeout = 5
#
[[hooks.external]]
event = "PreCompact"
type = "command"
matcher = "auto"             # only on the proactive fold, not the 413-reactive path
command = "./.polaris/hooks/precompact.sh"
#
[[hooks.external]]
event = "Stop"
type = "prompt"              # advisory: re-prompt the LLM for a completion check
prompt = "Given the transcript, is the user's task actually complete? Answer briefly."
model = "claude-haiku-4-5-20251001"
timeout = 30

# --- Context compaction -----------------------------------------------------
# How the history is shrunk when it grows large. Cheap deterministic stages (snip,
# microcompact) run every turn; the prefix-collapse stage folds old turns into one
# summary block. With a real provider and use_llm_summary on, that fold is an LLM
# summary (Track A); with no API key / --provider fake / disabled, it is a
# deterministic string join (Track B). Any summary failure degrades to Track B, so a
# run never breaks. AGENT_DISABLE_LLM_SUMMARY=1 pins a run to Track B.
[compression]
max_message_chars = 6000       # per-message size above which snip/microcompact trim
collapsed_keep_recent = 8      # recent turns kept verbatim by the Track B fold
use_llm_summary = true         # false (or AGENT_DISABLE_LLM_SUMMARY=1) forces Track B
summary_keep_recent = 8        # recent turns kept verbatim by the Track A fold
summary_input_max_chars = 16000 # hard cap on the prefix fed to the summary call
# Track A summary OUTPUT budget — a streamed escalation ladder (parity with the reference's
# streamed compact). Attempt 1 uses compact_summary_start_tokens; on a max_tokens truncation
# it escalates to compact_max_output_tokens, then to the model's hard ceiling
# (tokens.model_output_tokens(model)[1]: 128k for Opus 4.8). Streaming means the high tiers
# don't trip the SDK's non-streaming timeout. Any failure still degrades to Track B.
compact_summary_start_tokens = 8000  # first attempt (steady-state, ~ the reference's 8k slot cap)
compact_max_output_tokens = 20000    # middle tier (the reference's COMPACT_MAX_OUTPUT_TOKENS)
compact_max_output_retries = 2       # escalations allowed after the first attempt
summary_timeout_seconds = 120    # single (non-stacked) timeout (s) bounding the WHOLE ladder; omit/None disables
# Token-based auto-compact gate (parity with the reference). The gate compares a
# running token estimate (last response usage, else chars/4) against
# `effective_window - autocompact_buffer_tokens`, where the effective window reserves
# room for the summary output. The char fields below only bound per-message snip/
# microcompact budgets — they no longer drive the trigger.
# max_context_chars = 24000    # per-message microcompact budget basis (NOT the trigger)
# context_window_tokens caps the model's window for local auto-compact decisions.
# tokens.py now recognises the native 1M family (Opus 4.6/4.7/4.8, Sonnet 4.6, Fable/Mythos 5)
# and Haiku 4.5's 200k automatically, so this is only needed to MODEL A SMALLER deployment
# (e.g. a capped window) — leave unset otherwise.
# context_window_tokens = 200000
# autocompact_buffer_tokens = 13000        # headroom below the effective window before compaction fires
# reserved_output_tokens_for_summary = 20000 # tokens held back from the window for the summary's output
# max_consecutive_autocompact_failures = 3   # circuit breaker: stop retrying after this many failures
# AGENT_AUTOCOMPACT_PCT_OVERRIDE=<0..100> (env only) lowers the threshold to a
# percent of the effective window for easier testing.
# Post-compact file re-injection: after a real fold, re-attach the most-recently-read
# files as one untrusted <system-reminder> user message so file context isn't lost.
# post_compact_max_files = 5                 # most-recent files re-attached (newest first)
# post_compact_max_tokens_per_file = 5000    # per-file truncation cap (token-based, char/4)
# post_compact_total_budget_tokens = 20000   # total token budget across all re-attached files
# (CLAUDE.md is never re-attached here — it is already pinned as the userContext reminder.)

# --- Tool concurrency -------------------------------------------------------
# Same-turn tool calls run concurrently when their declared resources do not
# conflict. Disable this to force the old strictly serial execution path.
[concurrency]
parallel_tools = true          # false = execute tool calls one at a time
max_tool_workers = 10          # worker threads for one independent wave
# When several sub-agents/teammates run at once, their LLM API calls now overlap.
# These bound the shared budget across the whole fan-out (env: AGENT_MAX_API_CONCURRENCY,
# AGENT_API_RATE_LIMIT; CLI: --max-api-concurrency).
max_api_concurrency = 8        # max simultaneous in-flight LLM API calls
api_rate_limit_per_min = 0     # sustained requests/min ceiling; 0 = unlimited

# --- MCP servers (Model Context Protocol) -----------------------------------
# Optional. Each [mcp.servers.<name>] connects one MCP server and exposes its tools
# to the agent as "<name>__<tool>" (e.g. fs__read_file). The MCP SDK and the official
# git/fetch/time reference servers are core deps, available by default.
# Every tool defaults to risk = "dangerous" (so it's denied in auto/dontask and
# confirmed in default); set risk per server to "read" or "write" to relax that.
# Inspect what a server exposes with:  python -m agent_core mcp list
#
# # stdio transport — launch a server as a subprocess:
# [mcp.servers.fs]
# transport = "stdio"
# command = "python"
# args = ["-m", "mcp_server_filesystem", "."]
# # env = { SOME_VAR = "value" }   # extra env layered over the inherited environment
# # cwd = "."                       # working directory for the subprocess
# risk = "read"
#
# # Streamable HTTP transport (2025 spec, single endpoint) — connect to a URL:
# [mcp.servers.weather]
# transport = "streamable-http"
# url = "http://localhost:8000/mcp"
# headers = { Authorization = "Bearer TOKEN" }
# risk = "write"
#
# --- Popular community servers (uncomment + install to enable) ---------------
# These are Node-based; they run via `npx -y <pkg>` (needs Node/npm on PATH) and
# are NOT in the `mcp-servers` extra (that extra only carries the pip git/fetch/time
# servers). Each needs its own setup (tokens, paths) — see the package's README.
#
# # GitHub: repos, issues, PRs, code search. Needs a personal access token.
# [mcp.servers.github]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-github"]
# env = { GITHUB_PERSONAL_ACCESS_TOKEN = "ghp_..." }
# risk = "write"
#
# # Playwright: drive a real browser (navigate, click, screenshot, scrape).
# [mcp.servers.playwright]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@playwright/mcp@latest"]
# risk = "dangerous"
#
# # SQLite: query/inspect a local database file.
# [mcp.servers.sqlite]
# transport = "stdio"
# command = "npx"
# args = ["-y", "mcp-server-sqlite-npx", "./app.db"]
# risk = "write"
#
# # Sequential-thinking: a structured step-by-step reasoning scratchpad.
# [mcp.servers.sequential-thinking]
# transport = "stdio"
# command = "npx"
# args = ["-y", "@modelcontextprotocol/server-sequential-thinking"]
# risk = "read"

[mcp.servers.git]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_git", "--repository", "."]
risk = "write"

[mcp.servers.fetch]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_fetch"]
env = { PYTHONIOENCODING = "utf-8" }
risk = "read"

[mcp.servers.time]
transport = "stdio"
command = "python"
args = ["-m", "mcp_server_time", "--local-timezone=Asia/Shanghai"]
risk = "read"

# --- Single tool-output truncation ------------------------------------------
# When one tool call's output exceeds these limits, only a head preview (with the
# full output spilled to runs/<run>/outputs/) enters the context. Sized for a
# coding agent (Claude-Code-like): ordinary files come back whole, only huge output
# spills. read_text_file is always exempt — it self-pages via offset/limit.
[output]
max_lines = 2000              # truncate when output has more lines than this
max_chars = 50000             # fallback cap for pathological single-line output
head_lines = 20               # lines kept from the start (legacy mode, pointer=false)
tail_lines = 20               # lines kept from the end (legacy mode, pointer=false)
spill = true                  # write the full output to disk (false = drop it)
pointer = true                # replace oversized output with a <tool_output_ref> preview
                              #   pointer (head + on-disk path the model pages back via
                              #   read_text_file); false = legacy head+tail truncation
preview_chars = 4000          # head kept inline in the pointer (pointer mode only)

# Tool-use progress labels: after each tool batch, a cheap model (Haiku) is asked
# asynchronously for a one-line, git-subject-style label ("Searched auth/, fixed NPE")
# shown in the live UI as a progress indicator. It is UI-only and ephemeral: never sent
# to the model's context and never written to the resumable transcript (only the live UI
# and the runs/*.jsonl event log see it). Off by default — it costs one extra (small) API
# call per tool batch and only helps when a live terminal UI is attached.

# The tool_use_summary for the agent's nth operation appears before the output for the (n+1)th
# operation, which can confuse users (leading them to mistakenly believe it is the (n+1)th operation), 
# so set it to false.
[tool_use_summary]
enabled = false                       # opt-in; also requires a live UI + a real provider
model = "claude-haiku-4-5-20251001"   # the cheap model used to write the label
max_tokens = 64                       # labels are short — keep the budget tiny
max_input_chars_per_tool = 300        # head-truncate each tool's input/output before labeling
timeout_seconds = 8.0                 # single bound on the label call; on timeout, no label
include_subagents = false             # default: only the leader narrates (not sub-agents)
